# Copy this file to .env and fill in your values
# DO NOT commit .env to source control

# Your OpenAI-compatible proxy endpoint
OPENAI_API_BASE=https://your-openai-proxy.company.com/v1

# API key for the proxy
OPENAI_API_KEY=your-api-key-here

# Model name your proxy uses (update once confirmed)
MODEL_NAME=gpt-5.2

# Minimum score to earn certification (default 95)
PASS_THRESHOLD=95
